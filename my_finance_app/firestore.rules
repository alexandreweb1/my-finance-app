rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // True when the document being written declares the caller as owner.
    function isCreatingOwnDoc() {
      return request.resource.data.userId == request.auth.uid;
    }

    // True when the existing document belongs to the caller.
    function isOwnerOfExistingDoc() {
      return resource.data.userId == request.auth.uid;
    }

    // ── /users/{userId} ───────────────────────────────────────────────────────
    // Each user can only read / write their own profile document.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── /transactions/{transactionId} ─────────────────────────────────────────
    // A user may create a transaction that belongs to them,
    // and read / update / delete only their own transactions.
    match /transactions/{transactionId} {
      allow read, update, delete: if isSignedIn() && isOwnerOfExistingDoc();
      allow create:               if isSignedIn() && isCreatingOwnDoc();
    }

    // ── /categories/{categoryId} ──────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read, update, delete: if isSignedIn() && isOwnerOfExistingDoc();
      allow create:               if isSignedIn() && isCreatingOwnDoc();
    }

    // ── /budgets/{budgetId} ───────────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow read, update, delete: if isSignedIn() && isOwnerOfExistingDoc();
      allow create:               if isSignedIn() && isCreatingOwnDoc();
    }

    // ── /wallets/{walletId} ───────────────────────────────────────────────────
    match /wallets/{walletId} {
      allow read, update, delete: if isSignedIn() && isOwnerOfExistingDoc();
      allow create:               if isSignedIn() && isCreatingOwnDoc();
    }

    // ── /subscriptions/{userId} ───────────────────────────────────────────────
    // Document ID == userId; only the owner can read/write their subscription.
    match /subscriptions/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── /invitations/{invitationId} ───────────────────────────────────────────
    // Master: can create, read, update and delete their own invitations.
    // Invitee: can read and update (accept/decline) invitations sent to their email.
    match /invitations/{invitationId} {
      allow create: if isSignedIn()
                    && request.resource.data.masterUserId == request.auth.uid;

      allow read:   if isSignedIn()
                    && (resource.data.masterUserId == request.auth.uid
                        || resource.data.inviteeEmail == request.auth.token.email);

      allow update: if isSignedIn()
                    && (resource.data.masterUserId == request.auth.uid
                        || resource.data.inviteeEmail == request.auth.token.email);

      allow delete: if isSignedIn()
                    && resource.data.masterUserId == request.auth.uid;
    }
  }
}
